<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:fitsSystemWindows="true"> <TextView
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="Головне меню"
    android:textSize="26sp"
    android:textStyle="bold"
    android:layout_marginBottom="32dp"/>

    <Button
        android:id="@+id/btnCatalog"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="📚 Каталог курсів"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnMyCourses"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="🎓 Мої курси (Прогрес)"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnPrograms"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="📋 Навчальні програми"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnNews"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="📰 Новини платформи"/>
</LinearLayout>