<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Завдання 1: Сума чисел"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/inputSum1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Перше число"
            android:inputType="numberDecimal" />

        <EditText
            android:id="@+id/inputSum2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Друге число"
            android:inputType="numberDecimal" />

        <Button
            android:id="@+id/btnCalculateSum"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Знайти суму" />

        <TextView
            android:id="@+id/tvResultSum"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#2E7D32"
            android:textSize="16sp"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Завдання 2: Календар подій"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/inputDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Дата (напр. 24.05)" />

        <EditText
            android:id="@+id/inputEvent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Назва події" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <Button
                android:id="@+id/btnAddEvent"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Додати" />
            <Button
                android:id="@+id/btnViewEvents"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Переглянути" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvResultCalendar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#1565C0"
            android:textSize="16sp"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Завдання 3: Поле чудес"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvHiddenWord"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="_ _ _ _ _ _"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/inputLetter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Введіть одну літеру"
            android:maxLength="1"
            android:inputType="textCapCharacters" />

        <Button
            android:id="@+id/btnGuessLetter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Вгадати" />

        <TextView
            android:id="@+id/tvResultGame"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#E65100"
            android:textSize="16sp"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Завдання 4: Римські в арабські"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/inputRoman"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Римське число (напр. XIV)"
            android:inputType="textCapCharacters" />

        <Button
            android:id="@+id/btnConvertRoman"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Конвертувати" />

        <TextView
            android:id="@+id/tvResultRoman"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#6A1B9A"
            android:textSize="16sp"
            android:layout_marginBottom="24dp"/>

    </LinearLayout>
</ScrollView>